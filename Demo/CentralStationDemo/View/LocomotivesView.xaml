<UserControl x:Class="CentralStationDemo.View.LocomotivesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CentralStationDemo.View"
             xmlns:vm="clr-namespace:CentralStationDemo.ViewModel" 
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <GroupBox Header="Locomotives">
        <DataGrid 
            Grid.Row="4" 
            ItemsSource="{Binding Locomotives}" 
            AutoGenerateColumns="False" 
            IsReadOnly="True"
            HeadersVisibility="Column"
            GridLinesVisibility="None"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserResizeColumns="True"
            CanUserReorderColumns="True"
            CanUserSortColumns="True"
            IsSynchronizedWithCurrentItem="True"
            ClipboardCopyMode="IncludeHeader">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Uid" Binding="{Binding Uid}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Mfx Uid" Binding="{Binding MfxUid}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Icon Name" Binding="{Binding IconName}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="MfxType" Binding="{Binding MfxType}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="100" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Icon" Width="SizeToCells" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Icon}" Width="100" Height="20" Stretch="Uniform" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </GroupBox>
</UserControl>

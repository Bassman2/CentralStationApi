<AppWindowView x:Class="CentralStationDemo.View.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CentralStationDemo.View"
        xmlns:vm="clr-namespace:CentralStationDemo.ViewModel" 
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <local:SystemSyncView Grid.Row="0"/>
        <local:SystemAsyncView Grid.Row="1"/>
        <local:StatusView Grid.Row="2"/>
        <local:LocomotivesView Grid.Row="3"/>

        <DataGrid 
            Grid.Row="4" 
            ItemsSource="{Binding Messages}" 
            AutoGenerateColumns="False" 
            IsReadOnly="True"
            HeadersVisibility="Column"
            GridLinesVisibility="None"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserResizeColumns="True"
            CanUserReorderColumns="True"
            CanUserSortColumns="True"
            IsSynchronizedWithCurrentItem="True"
            ClipboardCopyMode="IncludeHeader"
            FontFamily="Courier"
            
            Margin="3,3,3,3" Grid.ColumnSpan="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="110"/>
                <DataGridTextColumn Header="Sender" Binding="{Binding Sender}" Width="110"/>
                <DataGridTextColumn Header="Binary" Binding="{Binding Binary}" Width="260"/>
                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="80"/>
                <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="140"/>
                <DataGridTextColumn Header="IsResponse" Binding="{Binding IsResponse}" Width="70"/>
                <DataGridTextColumn Header="Hash" Binding="{Binding Hash}" Width="50"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</AppWindowView>
